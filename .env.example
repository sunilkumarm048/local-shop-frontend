# Backend API (no trailing slash). Include /api at the end.
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Socket.IO server (NO /api — same root as backend host)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Auth.js (NextAuth v5) — used in Phase 2
AUTH_SECRET=replace-with-openssl-rand-hex-32
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Razorpay (publishable key only — secret stays on backend)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx

# Google Maps (browser-side; restrict to your domain in GCP console)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
